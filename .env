# Curae app runtime configuration.
#
# Base URL of the Curae backend (see backend/). Change this to point the app at
# a different host — no code edit needed.
#   Android emulator : http://10.0.2.2:8000
#   Physical device  : your machine's LAN IP, e.g. http://192.168.1.50:8000
#   Web / desktop    : http://localhost:8000
CURAE_API_BASE_URL=http://localhost:8000
